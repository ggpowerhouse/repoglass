# ====== OpenAI (required for real AI scoring; falls back to heuristic scorer if unset) ======
OPENAI_API_KEY=

# ====== GitHub (optional — boosts rate limit from 60/hr to 5000/hr) ======
GITHUB_TOKEN=

# ====== Supabase (optional — falls back to in-memory leaderboard if unset) ======
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ====== Admin console ======
# Defaults are dev-only. Rotate before you go live.
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=admin12345
# Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=
