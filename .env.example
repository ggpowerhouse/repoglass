# ============================================================================
# LLM provider (OpenAI-compatible). If none is set, RepoGlass falls back to
# the deterministic heuristic scorer — the app still works end-to-end.
# ============================================================================
#
# --- Option A: OpenAI ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
#
# --- Option B: Groq (OpenAI-compatible, free tier) ---
# LLM_API_KEY=gsk_...
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
#
# --- Option C: any other OpenAI-compatible provider ---
# (Together, Fireworks, OpenRouter, vLLM, LM Studio, Ollama...)
# LLM_API_KEY=...
# LLM_BASE_URL=https://.../v1
# LLM_MODEL=...
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

OPENAI_API_KEY=
OPENAI_MODEL=

# ============================================================================
# GitHub (optional — raises rate limit from 60/hr to 5000/hr).
# Use a fine-grained PAT with public repo read access only.
# ============================================================================
GITHUB_TOKEN=

# ============================================================================
# Supabase (optional — in-memory fallback is used when unset).
# Get these from Supabase Dashboard → Project Settings → API.
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================================
# Admin console.
# Rotate before you go live. ADMIN_SESSION_SECRET must be set in production.
# Generate with:  openssl rand -hex 32
# ============================================================================
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=admin12345
ADMIN_SESSION_SECRET=
